// BolderBrain — multi-tenant schema
// Isolation: enforced in Next.js middleware + route handlers (see src/middleware.ts, src/lib/tenant.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

// --- Auth.js / NextAuth (Prisma adapter) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isPlatformSuperAdmin Boolean @default(false)
  /// When false, user cannot sign in (org-level HR offboarding).
  isActive      Boolean   @default(true)

  accounts             Account[]
  sessions             Session[]
  organizationMembers  OrganizationMember[]
  assessmentsAsSubject Assessment[]         @relation("AssessmentSubject")
  assessmentsCreated   Assessment[]         @relation("AssessmentCreatedBy")
  assessmentEvaluators AssessmentEvaluator[]
  userActions             UserAction[]
  competencySnapshots     CompetencyScoreSnapshot[]
  developmentStreak       UserDevelopmentStreak?
  iqTestAttempts          IqTestAttempt[]
  eqTestAttempts          EqTestAttempt[]
  psychTestAttempts       PsychTestAttempt[]
  trainingEnrollments     TrainingEnrollment[]
  trainingAttempts        TrainingAttempt[]
  orgAssignmentsAssigned  OrgAssessmentAssignment[] @relation("OrgAssignmentAssignee")
  orgAssignmentsCreated   OrgAssessmentAssignment[] @relation("OrgAssignmentAssigner")
  aiInsights              AIInsight[]
  trainingNeeds           TrainingNeed[]
  skillsInventoryRows     SkillsInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Tenants ---

model Organization {
  id       String @id @default(cuid())
  slug     String @unique
  name     String
  settings Json?

  members             OrganizationMember[]
  assessmentTemplates AssessmentTemplate[]
  questions           Question[]
  assessments         Assessment[]
  insightRules        InsightRule[]
  competencies               Competency[]
  developmentAssignments     UserAction[]
  competencyScoreSnapshots   CompetencyScoreSnapshot[]
  iqTestAttempts             IqTestAttempt[]
  eqTestAttempts             EqTestAttempt[]
  psychTestAttempts          PsychTestAttempt[]
  trainingPrograms           TrainingProgram[]
  trainingContentTemplates   TrainingContentTemplate[]
  orgAssessmentAssignments   OrgAssessmentAssignment[]
  competencyTargets          CompetencyTarget[]
  trainingNeeds              TrainingNeed[]
  skillsInventoryRows        SkillsInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole
  /// Department / team label for org analytics (heatmap columns, filters).
  department     String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// --- Assessment templates (polymorphic: 360, IQ, EQ, psychometric) ---

enum AssessmentTemplateType {
  BEHAVIORAL_360
  IQ_COGNITIVE
  EQ_ASSESSMENT
  PSYCHOMETRIC
  /// Self-report skills audit; compared to CompetencyTarget to open TrainingNeeds.
  TNA_DIAGNOSTIC
}

enum ScoringStrategy {
  MULTI_SOURCE
  SUM_CORRECT
  TRAIT_AGGREGATE
}

enum AssessmentQuestionType {
  LIKERT_360
  SINGLE_CHOICE_IQ
  MULTI_CHOICE_IQ
  NUMERICAL_SEQUENCE
  VERBAL_ANALOGY
  LOGICAL_PATTERN
  SPATIAL_REASONING
  EQ_SCENARIO
  EQ_SELF_REPORT
  PSYCHOMETRIC_LIKERT
  FORCED_CHOICE_IPSATIVE
  SEMANTIC_DIFFERENTIAL
  TEXT_SHORT
  FREE_TEXT
}

model AssessmentTemplate {
  id                String                 @id @default(cuid())
  organizationId    String
  type              AssessmentTemplateType
  key               String
  name              String
  description       String?
  /// Type-specific settings (scales, time limits, norm tables, etc.).
  config            Json?
  scoringStrategy   ScoringStrategy
  sortOrder         Int                    @default(0)
  isActive          Boolean                @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questions    Question[]
  assessments  Assessment[]
  iqTestAttempts IqTestAttempt[]
  eqTestAttempts EqTestAttempt[]
  psychTestAttempts PsychTestAttempt[]
  trainingPrograms  TrainingProgram[]
  orgAssignments    OrgAssessmentAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

/// HR-admin assignment for IQ / EQ / psychometric (launch + monitor + remind). 360 and training use native models.
enum OrgAssessmentAssignmentKind {
  IQ_COGNITIVE
  EQ_ASSESSMENT
  PSYCHOMETRIC
}

enum OrgAssessmentAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model OrgAssessmentAssignment {
  id               String   @id @default(cuid())
  organizationId   String
  assignedUserId   String
  assignerUserId   String?
  kind             OrgAssessmentAssignmentKind
  templateId       String
  dueAt            DateTime?
  status           OrgAssessmentAssignmentStatus @default(PENDING)
  lastReminderAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser User               @relation("OrgAssignmentAssignee", fields: [assignedUserId], references: [id], onDelete: Cascade)
  assigner     User?              @relation("OrgAssignmentAssigner", fields: [assignerUserId], references: [id], onDelete: SetNull)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([organizationId, status])
  @@index([templateId])
}

model Question {
  id              String @id @default(cuid())
  organizationId  String
  templateId      String
  key             String
  questionType    AssessmentQuestionType
  /// Stems, options, branching — interpreted by the app; option `id` values referenced by correctOptionId.
  config          Json?
  /// For IQ / objective items: matches `options[].id` in config when using choice types.
  correctOptionId String?
  /// For EQ / psychometric: e.g. SelfAwareness, Empathy.
  traitCategory   String?
  weight          Decimal @default(1) @db.Decimal(12, 4)
  /// Optional per-item time budget (seconds); also may appear in `config` for overrides.
  timeLimitSeconds Int?
  /// EQ self-report: when true, Likert scores are reversed before scaling (higher raw = lower EQ).
  reverseScored   Boolean @default(false)
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses    AssessmentResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, key])
  @@index([organizationId])
  @@index([templateId])
}

enum IqAttemptStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

/// Self-administered IQ / cognitive test session (single-rater; pooled questions).
model IqTestAttempt {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  templateId     String
  status         IqAttemptStatus @default(IN_PROGRESS)
  startedAt      DateTime        @default(now())
  submittedAt    DateTime?
  /// Absolute deadline (server clock) for auto-submit.
  endsAt         DateTime
  /// Ordered question ids selected for this attempt (JSON string[]).
  questionIds    Json
  /// On submit: { [questionId]: selectedOptionId }
  responses      Json?
  /// Optional: question ids the user flagged for review (JSON string[]).
  flaggedIds     Json?

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  result       IqTestResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, templateId])
  @@index([organizationId])
  @@index([templateId])
}

model IqTestResult {
  id                  String   @id @default(cuid())
  attemptId           String   @unique
  rawCorrectCount     Int
  weightedScore       Float
  maxWeighted         Float
  standardScore       Float
  percentile          Float
  ciLow               Float
  ciHigh              Float
  categoryLabel       String
  breakdownByCategory Json
  interpretation      String   @db.Text

  attempt IqTestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum EqAttemptStatus {
  IN_PROGRESS
  COMPLETED
}

/// Self-administered EQ assessment with save/resume (draft responses on attempt).
model EqTestAttempt {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  templateId     String
  status         EqAttemptStatus @default(IN_PROGRESS)
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  /// Ordered question ids for this attempt (JSON string[]).
  questionIds    Json
  /// Draft or final: { [questionId]: { scenarioOptionId?: string, likert?: number } }
  responses      Json?
  /// Section index 0–4 for Goleman domains (ordered progress).
  currentSectionIndex Int       @default(0)
  lastSavedAt    DateTime?

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  result       EqTestResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, templateId])
  @@index([organizationId])
  @@index([templateId])
}

model EqTestResult {
  id                   String   @id @default(cuid())
  attemptId            String     @unique
  domainScores         Json
  compositeScore       Float
  percentileComposite  Float
  percentileByDomain   Json
  highestDomain        String
  lowestDomain         String
  consistencyFlags     Json
  narrativeText        String     @db.Text
  quadrantLabel        String
  heatmapPosition      Json
  /// Snapshot of previous completed result on same template (for growth comparison).
  previousSnapshot     Json?

  attempt EqTestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum PsychAttemptStatus {
  IN_PROGRESS
  COMPLETED
}

/// Big Five / OCEAN-style psychometric session (long-form; save/resume).
model PsychTestAttempt {
  id             String            @id @default(cuid())
  userId         String
  organizationId String
  templateId     String
  status         PsychAttemptStatus @default(IN_PROGRESS)
  startedAt      DateTime          @default(now())
  submittedAt    DateTime?
  questionIds    Json
  /// { [questionId]: PsychResponse }
  responses      Json?
  /// Current page index (0-based) when using paged UI.
  currentPageIndex Int            @default(0)
  lastSavedAt    DateTime?
  /// Per-question dwell time in ms (client-reported): { [questionId]: number }
  itemTimings    Json?

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  result       PsychTestResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, templateId])
  @@index([organizationId])
  @@index([templateId])
}

model PsychTestResult {
  id                String   @id @default(cuid())
  attemptId         String   @unique
  traitPercentiles  Json
  rawTraitSums      Json
  validityFlags     Json
  roleMatches       Json
  teamDynamicsText  String   @db.Text
  careerInsightsText String  @db.Text
  summaryLine       String
  /// Radar chart payload: user + population + optional ideal profile.
  radarPayload      Json

  attempt PsychTestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// --- Assessment instances (360 and future types) ---

enum AssessmentInstanceStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EvaluatorRole {
  SELF
  PEER
  MANAGER
}

enum EvaluatorStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Assessment {
  id              String                   @id @default(cuid())
  organizationId  String
  templateId      String
  /// Employee being assessed (ratee).
  subjectUserId   String
  title           String?
  status          AssessmentInstanceStatus @default(ACTIVE)
  createdByUserId String?
  /// Optional target date for completion (admin alerts / extensions).
  dueAt           DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  subject      User               @relation("AssessmentSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation("AssessmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  evaluators AssessmentEvaluator[]
  result     AssessmentResult?
  competencySnapshots CompetencyScoreSnapshot[]
  trainingNeedsAsSource TrainingNeed[] @relation("TrainingNeedSourceAssessment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([subjectUserId])
  @@index([templateId])
}

model AssessmentEvaluator {
  id           String          @id @default(cuid())
  assessmentId String
  userId       String
  role         EvaluatorRole
  status       EvaluatorStatus @default(PENDING)
  submittedAt  DateTime?

  assessment Assessment           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses  AssessmentResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentId, userId])
  @@index([userId])
  @@index([assessmentId])
}

model AssessmentResponse {
  id          String  @id @default(cuid())
  evaluatorId String
  questionId  String
  /// Likert scale 1–5 for LIKERT_360; optional for text items.
  numericValue Int?
  textValue    String? @db.Text

  evaluator AssessmentEvaluator @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  question  Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([evaluatorId, questionId])
  @@index([questionId])
  @@index([evaluatorId])
}

model AssessmentResult {
  id               String   @id @default(cuid())
  assessmentId     String   @unique
  /// Multi-source 360 scores per competency + summary (see app types).
  competencyScores Json
  computedAt       DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

/// Persisted AI + rule-based 360 insight (one row per completed assessment per user).
model AIInsight {
  id               String @id @default(cuid())
  userId           String
  assessmentId     String
  assessmentType   String

  aiGeneratedText  String? @db.Text
  ruleBasedText    String? @db.Text
  finalText        String  @db.Text

  source           String
  modelUsed        String?
  generationTimeMs Int?
  aiError          String?

  /// Parsed smart actions: [{ title, description, resource }]
  smartActionsJson Json?

  userRating Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assessmentId])
  @@index([userId, assessmentId])
}

// --- 360 insight rules (tenant-configurable; optional global defaults) ---

enum InsightSeverity {
  INFO
  WARNING
  POSITIVE
}

/// Rule-based insight templates. `competencyKey` matches 360 competency group name; null = any.
model InsightRule {
  id               String          @id @default(cuid())
  organizationId   String?
  /// Matches `Assessment360StoredResult.byCompetency[].competencyKey` when set.
  competencyKey    String?
  minGap           Decimal         @db.Decimal(6, 3)
  maxGap           Decimal         @db.Decimal(6, 3)
  messageTemplate  String          @db.Text
  severity         InsightSeverity @default(INFO)
  sortOrder        Int             @default(0)
  isActive         Boolean         @default(true)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
}

// --- Development: competencies, actions, user progress ---

enum ActionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum UserActionStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum UserActionSource {
  AUTO
  MANUAL
}

/// Org-level competency catalog; `key` should match 360 question `traitCategory` for auto-assignment.
model Competency {
  id             String @id @default(cuid())
  organizationId String
  key            String
  name           String
  description    String? @db.Text
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actions      Action[]
  competencyTargets CompetencyTarget[]
  trainingNeeds     TrainingNeed[]
  skillsInventoryRows SkillsInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Action {
  id            String           @id @default(cuid())
  competencyId  String
  title         String
  description   String           @db.Text
  difficulty    ActionDifficulty
  estimatedTime Int
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true)

  competency  Competency   @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  userActions UserAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([competencyId])
}

model UserAction {
  id               String           @id @default(cuid())
  userId           String
  actionId         String
  organizationId   String
  status           UserActionStatus @default(ASSIGNED)
  source           UserActionSource @default(AUTO)
  /// ISO week key e.g. 2025-W13
  weekKey          String
  assignedAt       DateTime         @default(now())
  completedAt      DateTime?
  notes            String?          @db.Text
  dismissReason    String?          @db.Text
  /// 360 assessment that triggered auto-assignment (idempotency).
  sourceAssessmentId String?
  /// EQ attempt that triggered auto-assignment (idempotency).
  sourceEqAttemptId  String?
  sourcePsychAttemptId String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       Action       @relation(fields: [actionId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, actionId, weekKey])
  @@index([userId, weekKey])
  @@index([userId, status])
  @@index([organizationId])
  @@index([sourceAssessmentId])
  @@index([sourceEqAttemptId])
  @@index([sourcePsychAttemptId])
}

model CompetencyScoreSnapshot {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  assessmentId   String
  competencyKey  String
  self           Float?
  peerAvg        Float?
  manager        Float?
  othersAverage  Float
  recordedAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, competencyKey, recordedAt])
  @@index([assessmentId])
}

model UserDevelopmentStreak {
  userId                    String  @id
  consecutiveWeeksCompleted Int     @default(0)
  lastCountedWeekKey        String?
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Flexible training content templates (Knowledge / Behavioral) — parallel to AssessmentTemplate ---

enum TrainingContentTemplateKind {
  KNOWLEDGE_TEST
  BEHAVIORAL_TEST
}

enum TrainingContentQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  LIKERT_5_SCALE
  LIKERT_FREQUENCY
  SEMANTIC_DIFFERENTIAL
}

/// Global (org null) or org-scoped templates for Training Impact programs.
model TrainingContentTemplate {
  id             String  @id @default(cuid())
  organizationId String?
  kind           TrainingContentTemplateKind
  name           String
  description    String?
  minQuestions   Int     @default(5)
  maxQuestions   Int     @default(50)
  defaultQuestionCount Int @default(20)
  hasTimer       Boolean @default(false)
  timeLimitMinutes Int?
  defaultOptionCount Int @default(4)
  isPublished    Boolean @default(false)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questions    TrainingContentQuestion[]
  trainingPrograms TrainingProgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model TrainingContentQuestion {
  id         String @id @default(cuid())
  templateId String
  text       String  @db.Text
  type       TrainingContentQuestionType
  /// Display order in builder; runtime order may shuffle.
  sortOrder  Int     @default(0)
  /// For knowledge tests: which option ids are correct (multiple for MULTIPLE_CHOICE).
  correctOptionIds String[] @default([])
  points     Int     @default(1)
  competencyKey String?
  reverseScored Boolean @default(false)
  minOptions Int     @default(3)
  maxOptions Int     @default(6)
  explanation String? @db.Text

  template TrainingContentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  options  TrainingContentOption[]

  @@index([templateId])
}

model TrainingContentOption {
  id         String @id @default(cuid())
  questionId String
  text       String
  sortOrder  Int    @default(0)
  /// For Likert: 1–5 weight; for knowledge: optional scoring weight.
  value      Int    @default(0)

  question TrainingContentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

enum TrainingAttemptPhase {
  PRE
  POST
}

model TrainingAttempt {
  id                   String @id @default(cuid())
  trainingProgramId    String
  trainingEnrollmentId String
  userId               String
  phase                TrainingAttemptPhase
  /// Ordered question ids as JSON string[] (may be shuffled).
  questionOrder        Json
  /// Per-question option id order for shuffle.
  optionShuffle        Json?
  /// Draft / final responses keyed by questionId.
  responses            Json?
  /// Scored payload (percent, byQuestion, etc.).
  scoreJson            Json?
  /// Set when the participant opens the attempt (timer anchor).
  startedAt            DateTime?
  submittedAt          DateTime?
  endsAt               DateTime?

  trainingProgram    TrainingProgram    @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  trainingEnrollment TrainingEnrollment @relation(fields: [trainingEnrollmentId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingEnrollmentId, phase])
  @@index([trainingProgramId])
  @@index([userId])
}

// --- Training Impact (pre/post paired assessments) ---

enum TrainingStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
}

enum EnrollmentStatus {
  INVITED
  PRE_COMPLETED
  TRAINING_COMPLETED
  POST_COMPLETED
}

/// Paired pre/post around a training event. Use **either** legacy 360 `templateId` **or** `trainingContentTemplateId`.
model TrainingProgram {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  description    String?
  /// Legacy: behavioral 360 template (optional when using flexible content template).
  templateId     String?
  /// Flexible knowledge / behavioral tests (Phase 14 refined).
  trainingContentTemplateId String?
  /// How many questions per attempt (random subset from pool).
  questionPoolCount Int?
  /// Same order for all vs random per participant.
  randomizePerParticipant Boolean @default(false)
  shufflePostQuestions Boolean @default(true)
  shufflePostOptions   Boolean @default(true)
  timerOverrideMinutes Int?
  scoringMode          String? @db.VarChar(50)
  partialCredit        Boolean @default(false)
  passThresholdPercent Int?
  allowRetake          Boolean @default(false)

  preOpensAt     DateTime
  preClosesAt    DateTime
  trainingDate   DateTime
  postOpensAt    DateTime
  postClosesAt   DateTime
  status         TrainingStatus @default(DRAFT)
  /// Manual cohort attendance (optional).
  attendanceCount   Int?
  attendanceExpected Int?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     AssessmentTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)
  trainingContentTemplate TrainingContentTemplate? @relation(fields: [trainingContentTemplateId], references: [id], onDelete: Restrict)
  enrollments  TrainingEnrollment[]
  attempts     TrainingAttempt[]
  trainingNeeds TrainingNeed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

// --- Training Needs Analysis (TNA / TNI) ---

enum CompetencyCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Expected proficiency by org competency; optional department / level scoping.
model CompetencyTarget {
  id             String @id @default(cuid())
  organizationId String
  competencyId   String
  /// Null = all departments.
  department     String?
  /// Null = all levels (e.g. IC, M1).
  careerLevel    String?
  targetScore    Float
  minimumScore   Float
  criticality    CompetencyCriticality @default(MEDIUM)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  competency   Competency   @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([competencyId])
}

enum TrainingNeedSource {
  TNA_ASSESSMENT
  MANAGER_NOMINATION
  SELF_IDENTIFIED
}

enum TrainingNeedStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum GapSeverity {
  EXCEEDS
  MET
  HIGH
  CRITICAL
}

model TrainingNeed {
  id               String @id @default(cuid())
  organizationId String
  userId           String
  competencyId   String
  /// Observed score when need was created (e.g. self / others avg).
  currentScore   Float?
  targetScore    Float
  /// Positive = below target (development need).
  gap            Float
  priority       Int                @default(0)
  source         TrainingNeedSource
  status         TrainingNeedStatus @default(OPEN)
  assignedProgramId String?
  /// Assessment that identified the gap (TNA or 360).
  sourceAssessmentId String?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  competency   Competency      @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  assignedProgram TrainingProgram? @relation(fields: [assignedProgramId], references: [id], onDelete: SetNull)
  sourceAssessment Assessment? @relation("TrainingNeedSourceAssessment", fields: [sourceAssessmentId], references: [id], onDelete: SetNull)

  notes      String?   @db.Text
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([competencyId])
  @@index([priority])
}

/// Latest aggregated gap row per user × competency (heatmap / inventory).
model SkillsInventory {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  competencyId   String
  currentScore   Float
  targetScore    Float
  gap            Float
  severity       GapSeverity
  gapCountHint   Int       @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  competency   Competency   @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId, competencyId])
  @@index([organizationId])
}

model TrainingEnrollment {
  id                String @id @default(cuid())
  trainingProgramId String
  userId            String

  preAssignmentId  String?
  postAssignmentId String?

  preScores  Json?
  postScores Json?
  delta      Json?

  status      EnrollmentStatus @default(INVITED)
  completedAt DateTime?

  trainingProgram TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts        TrainingAttempt[]

  @@unique([trainingProgramId, userId])
  @@index([userId])
  @@index([trainingProgramId])
}
